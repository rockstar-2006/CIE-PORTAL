{
    "name": "portal-app",
    "version": "0.1.0",
    "description": "CIE Portal - Code Submission and Evaluation Platform for Students and Administrators",
    "author": "CSE Department",
    "license": "MIT",
    "private": true,
    "main": "electron-main.js",
    "scripts": 
    {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "electron-dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
        "electron-build": "next build && set CSC_SKIP=true && electron-builder --publish never",
        "electron-release": "next build && set CSC_SKIP=true && electron-builder --publish always"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/rockstar-2006/CIE-PORTAL.git"
    },
    "dependencies": 
    {
        "@google/generative-ai": "^0.24.1",
        "@monaco-editor/react": "^4.7.0",
        "axios": "^1.15.0",
        "canvas-confetti": "^1.9.4",
        "firebase": "^12.12.0",
        "firebase-admin": "^13.8.0",
        "groq-sdk": "^1.1.2",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^1.8.0",
        "next": "16.2.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "xlsx": "^0.18.5"
    },
    "devDependencies": 
    {
        "concurrently": "^9.2.1",
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "wait-on": "^9.0.5"
    },
    "build": 
    {
        "appId": "com.university.cielauncher",
        "forceCodeSigning": false,
        "productName": "CIE Secure Launcher",
        "copyright": "Copyright © 2026 CSE Department",
        "asar": true,
        "buildDependenciesFromSource": false,
        "removePackageScripts": true,
        "files": 
        [
            "electron-main.js",
            "preload.js",
            "package.json",
            "public/favicon.ico"
        ],
        "extraMetadata": 
        {
            "main": "electron-main.js"
        },
        "win": 
        {
            "target": 
            [
                "nsis"
            ]
        },
        "nsis": 
        {
            "oneClick": false,
            "perMachine": false,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "runAfterFinish": true
        }
    }
}